---
import { Button } from "@starwind/button";
import { Dialog, DialogContent, DialogDescription, DialogHeader, DialogTitle, DialogTrigger } from "@starwind/dialog";
import { Icon } from "astro-icon/components";
---

<Dialog>
  <DialogTrigger asChild>
    <Button
      variant="primary"
      class="rounded-full font-bold px-6"
    >
      Ingresar
    </Button>
  </DialogTrigger>
  <DialogContent>
    <DialogHeader class="items-center pb-2 space-y-1">
      <span class="size-14 rounded-2xl bg-gradient-hero flex items-center justify-center">
        <Icon name="lucide:ticket" class="size-7 text-primary-foreground"/>
      </span>
      <DialogTitle class="text-xl font-extrabold">Ingresá a rifate.app</DialogTitle>
      <DialogDescription class="text-sm text-muted-foreground">Organizá y administrá tus rifas de forma simple</DialogDescription>
    </DialogHeader>

    <form
      class="pt-2 space-y-3"
      action="/api/auth/signin/google"
      method="POST"
    >
      <Button
        type="submit"
        variant="outline-accent"
        size="lg"
        class="w-full rounded-xl font-semibold text-base gap-3"
      >
        <Icon name="devicon:google" class="size-5" />
        Continuar con Google
      </Button>

      <p class="text-xs text-center text-muted-foreground">
        Al ingresar aceptás los términos y condiciones
      </p>
    </form>
  </DialogContent>
</Dialog>
