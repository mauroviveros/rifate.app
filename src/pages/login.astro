---
import { Button } from '@starwind/button';
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from '@starwind/card';
import { Icon } from 'astro-icon/components';

import Layout from '@/layouts/Layout.astro';

const next = Astro.url.searchParams.get('next');
const error = Astro.url.searchParams.get('error');
---

<Layout
  class="mx-auto flex h-dvh w-full max-w-md items-center justify-center p-4"
>
  <Card class="bg-secondary/10 text-secondary-foreground w-full border">
    <CardHeader class="flex flex-col items-center space-y-1 text-center">
      <span
        class="bg-gradient-hero flex size-14 items-center justify-center rounded-2xl"
      >
        <Icon name="lucide:ticket" class="text-primary-foreground size-7" />
      </span>
      <CardTitle class="text-xl font-extrabold">Ingresá a rifate.app</CardTitle>
      <CardDescription class="text-muted-foreground text-sm"
        >Organizá y administrá tus rifas de forma simple</CardDescription
      >
    </CardHeader>
    <CardContent>
      {
        error && (
          <p class="border-destructive/20 bg-destructive/10 text-destructive mb-4 rounded-xl border px-4 py-3 text-sm">
            No pudimos iniciar sesión. Intentalo de nuevo.
          </p>
        )
      }

      <form
        action="/api/auth/signin/google"
        method="POST"
        class="group space-y-3"
        aria-busy="false"
      >
        <input type="hidden" name="next" value={next} />

        <Button
          type="submit"
          variant="outline-accent"
          size="lg"
          class="relative w-full gap-3 rounded-xl text-base font-semibold"
        >
          <Icon name="devicon:google" class="size-5" />
          Continuar con Google

          <Icon
            name="lucide:loader-2"
            class="absolute right-4 hidden animate-spin group-aria-busy:block"
            aria-hidden="true"
          />
        </Button>

        <p class="text-muted-foreground text-center text-xs">
          Al ingresar aceptás los términos y condiciones
        </p>
      </form>
    </CardContent>
    <CardFooter class="justify-center">
      <a
        href="/"
        class="text-muted-foreground hover:text-primary text-sm transition-colors"
      >
        Volver al inicio
      </a>
    </CardFooter>
  </Card>
</Layout>

<script>
  const form = document.querySelector('form') as HTMLFormElement;

  window.addEventListener('pageshow', () => {
    form.removeAttribute('aria-busy');
    form
      .querySelectorAll('button')
      .forEach((btn) => btn.removeAttribute('disabled'));
  });

  form.addEventListener('submit', () => {
    form.setAttribute('aria-busy', 'true');
    form
      .querySelectorAll('button')
      .forEach((btn) => btn.setAttribute('disabled', 'true'));
  });
</script>
