---
import Button from '@starwind/button';
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from '@starwind/card';
import { Icon } from 'astro-icon/components';

import { RaffleGrid } from '@/components/raffle/grid/astro';
import PublicLayout from '@/layouts/PublicLayout.astro';

export function getStaticPaths() {
  return [{ params: { id: '1' } }];
}
---

<PublicLayout>
  <hgroup slot="header">
    <h1
      class="text-primary-foreground mb-1 text-2xl font-extrabold lg:text-3xl"
    >
      Rifa del Barrio - TV 50 pulgadas
    </h1>
    <p class="text-primary-foreground/70 max-w-lg text-sm">
      Gran rifa para juntar fondos para el club del barrio
    </p>
  </hgroup>

  <section class="grid gap-6 lg:grid-cols-[1fr_19rem]">
    <RaffleGrid editable={true} />

    <div class="space-y-4">
      <Card size="sm">
        <CardHeader>
          <CardTitle class="text-foreground font-bold"
            >¿Querés comprar?</CardTitle
          >
          <CardDescription class="text-muted-foreground text-sm"
            >Seleccioná los números que te interesan y contactá al organizador
            por WhatsApp.</CardDescription
          >
        </CardHeader>
        <CardContent>
          <Button variant="primary" class="w-full">
            <Icon name="lucide:message-circle" />
            Contactar al organizador
          </Button>
        </CardContent>
      </Card>

      <Card size="sm" class="bg-secondary/20 border-0">
        <CardContent>
          <p class="text-muted-foreground text-sm leading-relaxed">
            <strong>Tip:</strong> Tocá los números disponibles para seleccionar los
            que te interesan antes de contactar al organizador.
          </p>
        </CardContent>
      </Card>
    </div>
  </section>
</PublicLayout>
