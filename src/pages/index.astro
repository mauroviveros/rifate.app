---
import Button from '@starwind/button';
import { Icon } from 'astro-icon/components';

import RaffleGridExample from '@/components/raffle/RaffleGridExample.astro';
import LandingLayout from '@/layouts/LandingLayout.astro';
export const prerender = true;
---

<LandingLayout>
  <section
    class:list={[
      'min-h-[calc(100dvh-4rem)]',
      'container mx-auto max-w-6xl',
      'flex items-center',
    ]}
  >
    <div class="grid h-full items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <hgroup>
        <h1
          class="text-foreground mb-6 text-4xl font-black md:text-5xl xl:text-6xl"
        >
          Tu rifa digital, <br />
          <span class="text-primary">lista en minutos</span>
        </h1>
        <p class="text-muted-foreground mb-8 max-w-lg text-lg leading-relaxed">
          Creá rifas, vendé números y compartí el progreso con tus compradores.
          Ideal para barrios, escuelas, clubes y eventos.
        </p>

        <div class="flex flex-col gap-3 sm:flex-row">
          <Button
            href="/dashboard"
            variant="primary"
            size="lg"
            class="rounded-full font-bold"
          >
            Empezar ahora
            <Icon name="lucide:arrow-right" class="size-5" />
          </Button>
        </div>

        <div class="text-muted-foreground mt-8 flex items-center gap-6 text-sm">
          {
            ['Sin registros largos', 'Compartí por WhatsApp'].map((tip) => (
              <span class="flex items-center gap-1.5">
                <Icon
                  name="lucide:check-circle-2"
                  class="text-primary size-4"
                />
                {tip}
              </span>
            ))
          }
        </div>
      </hgroup>

      <div class="relative">
        <RaffleGridExample />
      </div>
    </div>
  </section>

  <!-- <section> <div class="container max-w-6xl mx-auto"></div> </section> -->
</LandingLayout>
